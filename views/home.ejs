<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Blog</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <div class="wrapper">
        <header class="app-header">
            <div class="logo-group">
                <h1>Blog</h1>
                <span class="badge">SYSTEM</span>
            </div>

            <div class="header-actions">
                <a href="/admin" class="btn-link nav-link">Admin Login</a>

                <button id="theme-toggle" class="btn-toggle-icon" type="button" aria-label="Toggle Theme">
                    <svg id="icon-sun" class="theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                    <svg id="icon-moon" class="theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                </button>
            </div>
        </header>

        <main class="card">
            <div class="card-header">
                <h1 class="card-title">Personal Blog</h1>
            </div>
            
            <ul class="article-list">
                <% if (articles.length === 0) { %>
                    <li class="article-item"><span class="article-date">No articles published yet.</span></li>
                <% } %>
                <% articles.forEach(article => { %>
                    <li class="article-item">
                        <a href="/article/<%= article.id %>" class="article-link"><%= article.title %></a>
                        <span class="article-date"><%= article.date %></span>
                    </li>
                <% }) %>
            </ul>
        </main>
        
        <footer class="project-footer">
            <p>Personal Blog System — Node.js Backed</p>
        </footer>
    </div>

    <script src="/javascripts/theme.js"></script>
</body>
</html>